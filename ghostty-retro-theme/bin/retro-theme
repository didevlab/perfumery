#!/usr/bin/env bash
# retro-theme — switch the Ghostty theme + toggle the screen effect (CRT/glow).
# Usage:
#   retro-theme                 -> interactive theme menu
#   retro-theme "Cyberpunk"     -> apply a theme directly
#   retro-theme -l              -> list ALL ghostty themes
#   retro-theme fx crt          -> retro CRT effect (curvature+scanlines)
#   retro-theme fx glow         -> futuristic effect (neon bloom)
#   retro-theme fx off          -> no effect (clean terminal)
#   retro-theme fx              -> show the current effect
# After applying: reload Ghostty with Ctrl+Shift+,
set -euo pipefail

CFG="$HOME/.config/ghostty/config"

# --- retro themes ---
RETRO=(
  "Retro"            # classic phosphor green
  "Hipster Green"    # vivid lime green
  "Apple Classic"    # vintage amber
  "C64"              # Commodore blue
  "IBM 5153 CGA"     # CGA gray
  "Hardcore"
  "Matrix"
)
# --- futuristic themes ---
FUTURO=(
  "Cyberpunk"        # pink/cyan neon
  "Synthwave"        # purple synthwave
  "TokyoNight"       # nocturnal blue
  "Aura"             # purple/green
  "Neon"
  "Cyberdyne"
  "Laser"
  "Spacedust"
)
# --- paper themes (light/e-ink) ---
PAPEL=(
  "Gruvbox Light"          # cream paper #fbf1c7
  "iTerm2 Solarized Light" # warm paper #fdf6e3
  "Catppuccin Latte"       # soft light gray
  "GitHub Light Default"   # pure white
  "Flexoki Light"          # off-white paper
  "Farmhouse Light"
)

THEMES_DIR="/snap/ghostty/current/share/ghostty/themes"
TCFG="$HOME/.config/terminator/config"

reload_hint() { echo "Reload Ghostty: Ctrl+Shift+,  (or open a new window). Terminator: open a new window."; }

# Mirror the ghostty theme colors into terminator (no CRT — impossible outside ghostty)
sync_terminator() {
  local theme="$1" tfile fg bg cur pal i c
  tfile="$THEMES_DIR/$theme"
  [[ -f "$tfile" && -f "$TCFG" ]] || return 0
  fg=$(grep -E '^foreground'   "$tfile" | head -1 | sed -E 's/^foreground = //')
  bg=$(grep -E '^background'   "$tfile" | head -1 | sed -E 's/^background = //')
  cur=$(grep -E '^cursor-color' "$tfile" | head -1 | sed -E 's/^cursor-color = //')
  [[ -n "$cur" ]] || cur="$fg"
  pal=""
  for i in $(seq 0 15); do
    c=$(grep -E "^palette = ${i}=" "$tfile" | head -1 | sed -E 's/^palette = [0-9]+=//')
    [[ -n "$c" ]] || c="$fg"
    pal+="${c}"; [[ $i -lt 15 ]] && pal+=":"
  done
  local tmp="${TCFG}.tmp.$$"
  awk -v fg="$fg" -v bg="$bg" -v cur="$cur" -v pal="$pal" '
    function printkeys() {
      printf "    use_theme_colors = False\n"
      printf "    foreground_color = \"%s\"\n", fg
      printf "    background_color = \"%s\"\n", bg
      printf "    cursor_color = \"%s\"\n", cur
      printf "    palette = \"%s\"\n", pal
    }
    BEGIN { ind=0; done=0 }
    /^[[:space:]]*\[\[default\]\]/ { ind=1; print; next }
    {
      if (ind && ($0 ~ /^[[:space:]]*\[\[/ || $0 ~ /^\[[^[]/)) {
        if (!done) { printkeys(); done=1 }
        ind=0; print; next
      }
      if (ind) {
        if ($0 ~ /^[[:space:]]*use_theme_colors[[:space:]]*=/) next
        if ($0 ~ /^[[:space:]]*foreground_color[[:space:]]*=/) next
        if ($0 ~ /^[[:space:]]*background_color[[:space:]]*=/) next
        if ($0 ~ /^[[:space:]]*cursor_color[[:space:]]*=/) next
        if ($0 ~ /^[[:space:]]*palette[[:space:]]*=/) next
        print; next
      }
      print
    }
    END { if (ind && !done) printkeys() }
  ' "$TCFG" > "$tmp" && mv "$tmp" "$TCFG" && echo "Terminator synced."
}

apply_theme() {
  local theme="$1"
  if grep -qE '^[[:space:]]*theme[[:space:]]*=' "$CFG"; then
    sed -i -E "s|^[[:space:]]*theme[[:space:]]*=.*|theme = ${theme}|" "$CFG"
  else
    printf '\ntheme = %s\n' "$theme" >> "$CFG"
  fi
  echo "Theme: ${theme}"
  sync_terminator "$theme"
  reload_hint
}

current_fx() {
  local line
  line=$(grep -E '^[[:space:]]*custom-shader[[:space:]]*=' "$CFG" 2>/dev/null | head -1 || true)
  case "$line" in
    *crt.glsl*)  echo "crt"  ;;
    *glow.glsl*) echo "glow" ;;
    *)           echo "off"  ;;
  esac
}

set_fx() {
  local mode="$1"
  # remove any custom-shader = line (leaves custom-shader-animation alone)
  sed -i -E '/^[[:space:]]*#?[[:space:]]*custom-shader[[:space:]]*=/d' "$CFG"
  case "$mode" in
    crt)  printf 'custom-shader = shaders/crt.glsl\n'  >> "$CFG"; echo "Effect: retro CRT" ;;
    glow) printf 'custom-shader = shaders/glow.glsl\n' >> "$CFG"; echo "Effect: futuristic glow" ;;
    off)  echo "Effect: off (clean terminal)" ;;
    *)    echo "invalid fx. Use: crt | glow | off" >&2; exit 1 ;;
  esac
  reload_hint
}

# --- fx subcommand ---
if [[ "${1:-}" == "fx" ]]; then
  if [[ -n "${2:-}" ]]; then set_fx "$2"; else echo "Current effect: $(current_fx)"; fi
  exit 0
fi

# --- full list ---
if [[ "${1:-}" == "-l" ]]; then
  ghostty +list-themes 2>/dev/null | sed -E 's/ \(resources\)//'
  exit 0
fi

# --- direct argument = theme name ---
if [[ $# -ge 1 ]]; then
  apply_theme "$1"
  exit 0
fi

# --- interactive menu ---
ALL=("${RETRO[@]}" "${FUTURO[@]}" "${PAPEL[@]}")
echo "== RETRO =="
for i in "${!RETRO[@]}"; do printf "  %2d) %s\n" "$((i+1))" "${RETRO[$i]}"; done
echo "== FUTURISTIC =="
o2=${#RETRO[@]}
for i in "${!FUTURO[@]}"; do printf "  %2d) %s\n" "$((o2+i+1))" "${FUTURO[$i]}"; done
echo "== PAPER (light) =="
o3=$(( ${#RETRO[@]} + ${#FUTURO[@]} ))
for i in "${!PAPEL[@]}"; do printf "  %2d) %s\n" "$((o3+i+1))" "${PAPEL[$i]}"; done
echo
echo "(screen effect: 'retro-theme fx crt|glow|off' — paper pairs well with 'off')"
read -rp "Choose [1-${#ALL[@]}]: " n
if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= ${#ALL[@]} )); then
  apply_theme "${ALL[$((n-1))]}"
else
  echo "Invalid option." >&2
  exit 1
fi
